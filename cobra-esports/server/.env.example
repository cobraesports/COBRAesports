# Скопируй в .env и заполни своими значениями. НИКОГДА не коммить .env.

PORT=5000

# Получить ключ: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# URL, на который Steam вернёт пользователя после логина
STEAM_RETURN_URL=http://localhost:5000/api/auth/steam/return
STEAM_REALM=http://localhost:5000/

# Куда редиректить обратно на фронтенд после успешного логина
CLIENT_URL=http://localhost:5173

# Секрет для express-session (сгенерируй случайную строку)
SESSION_SECRET=change_me_to_a_random_string

# Основная статистика CS2 (K/D, ADR, headshot%, wins, часы в игре и т.д.) берётся
# напрямую из официального Steam Web API (нужен только STEAM_API_KEY выше).
# CS2_STATS_API_URL/KEY нужны только если подключаете СТОРОННИЙ провайдер истории
# матчей и Rating 2.0 (например Leetify/FACEIT) — Steam такого публично не отдаёт.
# Пока эти переменные пустые, /api/matches/:steamId возвращает пустой список.
CS2_STATS_API_URL=
CS2_STATS_API_KEY=

# Отдельный провайдер статистики FACEIT (не Steam). Ключ получить тут:
# https://developers.faceit.com/apps -> Data API key. Пока FACEIT_API_KEY пустой,
# GET /api/faceit/:steamId отвечает 503, а не выдуманными данными.
FACEIT_API_URL=https://open.faceit.com/data/v4
FACEIT_API_KEY=

